{
  "expo": {
    "name": "Medá Fintech",
    "slug": "medaapp-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "medaagentes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meda.agentes",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.medafintech",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/brand/icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BinancePlex.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/logo_meda.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/brand/logo_meda.png",
            "backgroundColor": "#060612"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Medá usa la cámara para escanear el código QR de otros usuarios."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "8303c723-6fd9-49b1-bbc8-7042ed4db951"
      }
    },
    "owner": "medafintech"
  }
}
